          "ewgDataLabel": {
            "type": "keyword"
          },
          "ewgUrl": {"type": "text", "index": false },          
          "ewgChngDttm": {
            "type": "date", 
            "format": "yyyy-MM-dd HH:mm:ss"
          }         
        }
      },
      "rawDetailInfo":{
        "type": "nested",
        "properties": {
          "rawSeq": { "type": "integer", "index": false },
          "rawDetailSeq": {
